{
  "name": "lura-overlay",
  "version": "1.0.3",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "ably": "^2.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0",
    "electron": "^30.0.0"
  },
  "build": {
    "appId": "adi.lura.overlay",
    "productName": "Lura Overlay",
    "files": ["main.js", "index.html", "images/**"],
    "win": {
      "target": "portable",
      "icon": "images/1.png"
    },
    "mac": {
      "target": "dir",
      "icon": "images/1.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "images/1.png",
      "category": "Utility"
    }
  }
}